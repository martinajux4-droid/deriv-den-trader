  "loadingScreen": {
    "html": "<div class=\"bmt5x\"><style>.bmt5x{--c:#22e6b3;--c2:#00b7a8;--m:#ff3cff;--bg:#060a0b;--txt:rgba(245,255,253,.92);--mut:rgba(245,255,253,.62);--ln:rgba(34,230,179,.18);--ln2:rgba(0,183,168,.14);position:relative;width:100%;height:100%;min-height:100%;display:flex;align-items:center;justify-content:center;overflow:hidden;background:radial-gradient(1200px 600px at 50% -18%,rgba(34,230,179,.14),transparent 62%),radial-gradient(1000px 520px at 100% 112%,rgba(0,183,168,.12),transparent 60%),radial-gradient(900px 620px at -8% 95%,rgba(255,60,255,.07),transparent 58%),linear-gradient(180deg,#020304 0%,var(--bg) 55%,#020304 100%);font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,\"Segoe UI\",sans-serif}.bmt5x *{box-sizing:border-box}.bmt5x::before{content:\"\";position:absolute;inset:-20%;background:conic-gradient(from 220deg at 52% 48%,rgba(34,230,179,.18),rgba(0,183,168,.08),rgba(255,60,255,.10),rgba(0,0,0,0));filter:blur(44px);opacity:.75;animation:bmxAur 8.8s ease-in-out infinite}.bmt5x::after{content:\"\";position:absolute;inset:0;background:repeating-linear-gradient(180deg,rgba(255,255,255,.035),rgba(255,255,255,.035) 1px,transparent 1px,transparent 5px);opacity:.18;mix-blend-mode:overlay;pointer-events:none}@keyframes bmxAur{0%,100%{transform:translate3d(-1.5%,1%,0) rotate(-8deg) scale(1)}50%{transform:translate3d(1.5%,-1%,0) rotate(8deg) scale(1.02)}}.bmx-noise{position:absolute;inset:0;background-image:url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"160\" height=\"160\"><filter id=\"n\"><feTurbulence type=\"fractalNoise\" baseFrequency=\".9\" numOctaves=\"2\" stitchTiles=\"stitch\"/></filter><rect width=\"160\" height=\"160\" filter=\"url(%23n)\" opacity=\".22\"/></svg>');opacity:.06;mix-blend-mode:overlay;pointer-events:none}.bmx-circuit{position:absolute;inset:-2px;opacity:.72;background-image:radial-gradient(circle at 12px 12px,rgba(34,230,179,.22) 1px,transparent 2px),radial-gradient(circle at 64px 26px,rgba(0,183,168,.18) 1px,transparent 2px),linear-gradient(rgba(34,230,179,.065) 1px,transparent 1px),linear-gradient(90deg,rgba(0,183,168,.055) 1px,transparent 1px);background-size:96px 96px,128px 128px,46px 46px,46px 46px;mask-image:radial-gradient(ellipse 70% 55% at 50% 55%,#000 60%,transparent 82%);animation:bmxCircuit 16s linear infinite;transform:translateY(2%)}@keyframes bmxCircuit{0%{background-position:0 0,0 0,0 0,0 0}100%{background-position:-520px -320px,-420px -260px,-460px -460px,-460px -460px}}.bmx-scan{position:absolute;left:-10%;right:-10%;top:18%;height:42%;background:linear-gradient(180deg,transparent,rgba(34,230,179,.05),rgba(255,60,255,.025),rgba(0,183,168,.04),transparent);animation:bmxScan 3.3s ease-in-out infinite;mix-blend-mode:screen;filter:blur(.2px)}@keyframes bmxScan{0%,100%{transform:translateY(-35%);opacity:.35}50%{transform:translateY(38%);opacity:1}}.bmx-frame{position:relative;z-index:2;width:min(820px,94vw);border-radius:18px;background:linear-gradient(180deg,rgba(8,14,14,.74),rgba(6,10,10,.46));border:1px solid rgba(34,230,179,.14);box-shadow:0 30px 90px rgba(0,0,0,.68),0 0 0 1px rgba(0,0,0,.55) inset;backdrop-filter:blur(16px) saturate(1.2);-webkit-backdrop-filter:blur(16px) saturate(1.2);overflow:hidden}.bmx-frame::before{content:\"\";position:absolute;inset:-1px;background:radial-gradient(720px 260px at 18% 0%,rgba(34,230,179,.16),transparent 62%),radial-gradient(680px 260px at 100% 30%,rgba(0,183,168,.14),transparent 62%),radial-gradient(560px 240px at 0% 100%,rgba(255,60,255,.06),transparent 60%);opacity:.95;pointer-events:none}.bmx-corners{position:absolute;inset:0;pointer-events:none}.bmx-corners i{position:absolute;width:18px;height:18px;border:2px solid rgba(34,230,179,.55)}.bmx-corners i:nth-child(1){left:14px;top:14px;border-right:none;border-bottom:none}.bmx-corners i:nth-child(2){right:14px;top:14px;border-left:none;border-bottom:none;border-color:rgba(0,183,168,.55)}.bmx-corners i:nth-child(3){left:14px;bottom:14px;border-right:none;border-top:none;border-color:rgba(0,183,168,.55)}.bmx-corners i:nth-child(4){right:14px;bottom:14px;border-left:none;border-top:none;border-color:rgba(34,230,179,.55)}.bmx-top{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:22px 22px 0}.bmx-tag{display:flex;align-items:center;gap:10px;color:rgba(245,255,253,.72);font-size:10px;letter-spacing:.36em;text-transform:uppercase;white-space:nowrap}.bmx-tag b{color:rgba(245,255,253,.92);font-weight:800;letter-spacing:.26em}.bmx-tag .dot{width:8px;height:8px;border-radius:999px;background:var(--c);box-shadow:0 0 16px rgba(34,230,179,.7),0 0 34px rgba(0,183,168,.25);animation:bmxPulse 1.1s ease-in-out infinite}@keyframes bmxPulse{0%,100%{transform:scale(.86);opacity:.62}50%{transform:scale(1.06);opacity:1}}.bmx-title{padding:0 22px 18px}.bmx-h1{margin:10px 0 4px;font-size:34px;letter-spacing:.22em;text-transform:uppercase;font-weight:900;line-height:1.05;color:rgba(245,255,253,.92);text-shadow:0 0 40px rgba(34,230,179,.18)}.bmx-h1 span{position:relative;display:inline-block}.bmx-h1 span::before,.bmx-h1 span::after{content:attr(data-t);position:absolute;left:0;top:0;opacity:.85;mix-blend-mode:screen}.bmx-h1 span::before{transform:translate(1px,0);color:rgba(34,230,179,.9);clip-path:inset(0 0 55% 0);animation:bmxGl1 2.1s infinite linear}.bmx-h1 span::after{transform:translate(-1px,0);color:rgba(255,60,255,.72);clip-path:inset(55% 0 0 0);animation:bmxGl2 2.6s infinite linear}@keyframes bmxGl1{0%{clip-path:inset(0 0 75% 0)}45%{clip-path:inset(0 0 55% 0)}100%{clip-path:inset(0 0 78% 0)}}@keyframes bmxGl2{0%{clip-path:inset(62% 0 0 0)}50%{clip-path:inset(52% 0 0 0)}100%{clip-path:inset(66% 0 0 0)}}.bmx-sub{margin:0;font-size:12px;letter-spacing:.14em;color:rgba(245,255,253,.62)}.bmx-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:16px;padding:0 22px 18px}@media(max-width:780px){.bmx-grid{grid-template-columns:1fr}.bmx-h1{font-size:30px}}.bmx-card{border-radius:14px;border:1px solid rgba(34,230,179,.14);background:rgba(2,6,6,.34);box-shadow:0 0 0 1px rgba(34,230,179,.04) inset;padding:14px 14px 12px;position:relative;overflow:hidden}.bmx-card::after{content:\"\";position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(34,230,179,.09),transparent);transform:translateX(-120%);animation:bmxSweep 2.2s ease-in-out infinite;opacity:.7}@keyframes bmxSweep{0%{transform:translateX(-120%)}55%{transform:translateX(120%)}100%{transform:translateX(120%)}}.bmx-card h2{margin:0 0 10px;font-size:10px;letter-spacing:.34em;text-transform:uppercase;color:rgba(245,255,253,.78);font-weight:900}.bmx-k{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}@media(max-width:780px){.bmx-k{grid-template-columns:repeat(2,minmax(0,1fr))}}.bmx-k div{border-radius:12px;border:1px solid rgba(0,183,168,.14);background:rgba(10,18,18,.30);padding:11px 11px 9px}.bmx-k .l{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgba(245,255,253,.52);margin-bottom:6px}.bmx-k .v{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:14px;font-weight:800;color:rgba(245,255,253,.92);letter-spacing:.08em}.bmx-log{border-radius:14px;border:1px solid rgba(255,60,255,.12);background:rgba(3,6,6,.30);padding:14px 14px 12px;position:relative;overflow:hidden}.bmx-log h2{margin:0 0 10px;font-size:10px;letter-spacing:.34em;text-transform:uppercase;color:rgba(245,255,253,.78);font-weight:900}.bmx-lines{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:11px;line-height:1.55;color:rgba(245,255,253,.64)}.bmx-lines b{color:rgba(34,230,179,.9)}.bmx-lines em{font-style:normal;color:rgba(255,60,255,.72)}.bmx-lines span{display:block;opacity:.9;animation:bmxType 1.9s infinite}@keyframes bmxType{0%,10%{opacity:.0;transform:translateY(2px)}25%,100%{opacity:1;transform:translateY(0)}}.bmx-lines span:nth-child(2){animation-delay:.2s}.bmx-lines span:nth-child(3){animation-delay:.4s}.bmx-lines span:nth-child(4){animation-delay:.6s}.bmx-lines span:nth-child(5){animation-delay:.8s}.bmx-foot{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:14px 22px 18px;border-top:1px solid rgba(34,230,179,.10);color:rgba(245,255,253,.55);font-size:10px;letter-spacing:.18em;text-transform:uppercase}.bmx-foot .dots span{display:inline-block;animation:bmxDot 1.25s infinite}@keyframes bmxDot{0%,80%,100%{opacity:.18}40%{opacity:1}}.bmx-foot .dots span:nth-child(2){animation-delay:.2s}.bmx-foot .dots span:nth-child(3){animation-delay:.4s}</style><div class=\"bmx-circuit\" aria-hidden=\"true\"></div><div class=\"bmx-scan\" aria-hidden=\"true\"></div><div class=\"bmx-noise\" aria-hidden=\"true\"></div><div class=\"bmx-frame\" role=\"status\" aria-live=\"polite\" aria-label=\"Loading BMT5\"><div class=\"bmx-corners\" aria-hidden=\"true\"><i></i><i></i><i></i><i></i></div><div class=\"bmx-top\"><div class=\"bmx-tag\"><span class=\"dot\" aria-hidden=\"true\"></span><b>pattern scanner</b> // secure bootstrap</div><div class=\"bmx-tag\">node <b>edge-9</b></div></div><div class=\"bmx-title\"><div class=\"bmx-h1\"><span data-t=\"BMT5\">BMT5</span></div><p class=\"bmx-sub\">HUD overlay online • liquidity route locked • initiating chart fabric</p></div><div class=\"bmx-grid\"><div class=\"bmx-card\"><h2>telemetry</h2><div class=\"bmx-k\" aria-hidden=\"true\"><div><div class=\"l\">channel</div><div class=\"v\">L2</div></div><div><div class=\"l\">auth</div><div class=\"v\"><b>PKCE</b></div></div><div><div class=\"l\">sync</div><div class=\"v\">OK</div></div></div></div><div class=\"bmx-log\"><h2>boot log</h2><div class=\"bmx-lines\"><span><em>[init]</em> allocating workspace…</span><span><em>[net]</em> edge handshake <b>secured</b></span><span><em>[chart]</em> loading indicators…</span><span><em>[stream]</em> subscribing ticks…</span><span><em>[ui]</em> rendering HUD layers…</span></div></div></div><div class=\"bmx-foot\"><div>status <b class=\"loader-status\">bootstrapping</b> <span class=\"dots\" aria-hidden=\"true\"><span>.</span><span>.</span><span>.</span></span></div><div>powered by deriv</div></div></div></div>"
