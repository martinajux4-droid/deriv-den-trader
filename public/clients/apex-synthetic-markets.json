t:600;letter-spacing:0.35em;text-transform:uppercase;color:var(--g);opacity:0.85;border:1px solid rgba(230,195,77,0.35);border-radius:999px;padding:6px 14px;margin-bottom:20px;animation:apexFade 1s ease 0.1s both;background:rgba(92,74,8,0.25);}.apex-ls__name{font-size:clamp(28px,8vw,40px);font-weight:700;letter-spacing:0.28em;color:var(--g);text-shadow:0 0 42px rgba(230,195,77,0.35),0 2px 0 rgba(0,0,0,0.45);animation:apexFade 0.9s ease 0.2s both,apexGlow 2.8s ease-in-out infinite;margin:0 0 6px;}@keyframes apexGlow{0%,100%{filter:brightness(1);}50%{filter:brightness(1.15);}}.apex-ls__sub{font-size:13px;font-weight:500;letter-spacing:0.12em;color:rgba(230,215,180,0.75);margin:0 0 28px;animation:apexFade 1s ease 0.35s both;}.apex-ls__chart{width:100%;max-width:280px;margin:0 auto 22px;height:52px;animation:apexFade 1.1s ease 0.45s both;}.apex-ls__chart path{fill:none;stroke:url(#apexGrad);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:320;stroke-dashoffset:320;animation:apexDraw 2.4s ease forwards 0.5s;}@keyframes apexDraw{to{stroke-dashoffset:0;}}.apex-ls__candles{display:flex;justify-content:center;align-items:flex-end;gap:10px;height:40px;margin-bottom:26px;animation:apexFade 1.2s ease 0.55s both;}.apex-ls__c{width:5px;border-radius:1px;background:var(--g);animation:apexCandle 1.4s ease-in-out infinite;box-shadow:0 0 12px rgba(230,195,77,0.25);}.apex-ls__c:nth-child(1){height:18px;animation-delay:0s;}.apex-ls__c:nth-child(2){height:28px;opacity:0.85;animation-delay:0.12s;}.apex-ls__c:nth-child(3){height:36px;animation-delay:0.24s;}.apex-ls__c:nth-child(4){height:22px;opacity:0.9;animation-delay:0.36s;}.apex-ls__c:nth-child(5){height:30px;animation-delay:0.48s;}@keyframes apexCandle{0%,100%{transform:scaleY(1);opacity:0.85;}50%{transform:scaleY(1.08);opacity:1;}}.apex-ls__bar{height:3px;border-radius:3px;background:rgba(230,195,77,0.12);overflow:hidden;margin-bottom:14px;position:relative;}.apex-ls__bar>i{display:block;height:100%;width:38%;background:linear-gradient(90deg,var(--gd),var(--g),var(--g2));border-radius:3px;animation:apexSweep 1.85s ease-in-out infinite;box-shadow:0 0 16px rgba(230,195,77,0.45);}@keyframes apexSweep{0%{transform:translateX(-100%);}100%{transform:translateX(280%);}}.apex-ls__status{font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(230,215,180,0.55);animation:apexFade 1.3s ease 0.65s both;}.apex-ls__status span{display:inline-block;animation:apexDot 1.4s infinite;}.apex-ls__status span:nth-child(2){animation-delay:0.2s;}.apex-ls__status span:nth-child(3){animation-delay:0.4s;}@keyframes apexDot{0%,80%,100%{opacity:0.25;}40%{opacity:1;}}@keyframes apexFade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}</style><div class=\"apex-ls__grid\" aria-hidden=\"true\"></div><div class=\"apex-ls__scan\" aria-hidden=\"true\"></div><div class=\"apex-ls__ring\" aria-hidden=\"true\"></div><div class=\"apex-ls__ring apex-ls__ring--2\" aria-hidden=\"true\"></div><div class=\"apex-ls__inner\"><div class=\"apex-ls__pill\">Synthetic indices</div><h1 class=\"apex-ls__name\">APEX</h1><p class=\"apex-ls__sub\">Synthetic Markets</p><svg class=\"apex-ls__chart\" viewBox=\"0 0 280 52\" aria-hidden=\"true\"><defs><linearGradient id=\"apexGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\"><stop offset=\"0%\" stop-color=\"#5c4a08\"/><stop offset=\"55%\" stop-color=\"#c9a227\"/><stop offset=\"100%\" stop-color=\"#e6c34d\"/></linearGradient></defs><path d=\"M4,42 L32,38 L58,40 L86,28 L112,32 L138,18 L164,22 L190,12 L216,16 L242,8 L268,14\"/></svg><div class=\"apex-ls__candles\" aria-hidden=\"true\"><div class=\"apex-ls__c\"></div><div class=\"apex-ls__c\"></div><div class=\"apex-ls__c\"></div><div class=\"apex-ls__c\"></div><div class=\"apex-ls__c\"></div></div><div class=\"apex-ls__bar\" aria-hidden=\"true\"><i></i></div><p class=\"apex-ls__status loader-status\">Initializing<span>.</span><span>.</span><span>.</span></p><p class=\"apex-ls__sub\"